generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SHIPPER
  DRIVER
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  COMPLETED
  DISPUTED
}

// Distinguishes instant matching from scheduled bookings
enum BookingType {
  INSTANT
  SCHEDULED
}

enum VehicleType {
  TWO_WHEELER
  THREE_WHEELER
  MINI_TEMPO
  PICKUP_TRUCK
  CONTAINER_3TON
  HEAVY_DUTY_TRUCK
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipperBookings Booking[] @relation("ShipperBookings")
  driverBookings  Booking[] @relation("DriverBookings")
  driverProfile   DriverProfile?
  vehicle         Vehicle?

  @@map("users")
  sessions        Session[]
}

model DriverProfile {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOnline  Boolean   @default(false)
  latitude  Float?
  longitude Float?
  updatedAt DateTime  @updatedAt

  @@map("driver_profiles")
  @@index([isOnline])
}

model Vehicle {
  id           String      @id @default(uuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         VehicleType
  plateNumber  String
  capacityKg   Int
  basePrice    Float       @default(50)
  pricePerKm   Float       @default(15)
  costPerUnit  Float       @default(5)

  @@map("vehicles")
}

model Booking {
  id              String        @id @default(uuid())
  shipperId       String
  shipper         User          @relation("ShipperBookings", fields: [shipperId], references: [id], onDelete: Cascade)
  driverId        String?
  driver          User?         @relation("DriverBookings", fields: [driverId], references: [id], onDelete: SetNull)
  status          BookingStatus @default(PENDING)

  pickupLat       Float
  pickupLng       Float
  pickupAddress   String        @default("Unknown Pickup Address")
  dropoffLat      Float
  dropoffLng      Float
  dropoffAddress  String        @default("Unknown Dropoff Address")

  cargoType       String
  weightKg        Float
  lengthCm        Float
  widthCm         Float
  heightCm        Float
  volumetricWeight Float
  vehicleType      VehicleType

  distanceKm      Float
  price           Float

  pickupOTP       String?
  dropoffOTP      String?
  pickupVerified  Boolean       @default(false)
  dropoffVerified Boolean       @default(false)
  otpGeneratedAt  DateTime?

  // Fields for scheduled delivery options
  bookingType     BookingType   @default(INSTANT)
  scheduledAt     DateTime?     
  scheduledUntil  DateTime?     
  committedAt     DateTime?     
  otpAttempts     Int           @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("bookings")
  @@index([shipperId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([scheduledAt])
  @@index([bookingType])

  review         Review?
  dispute        Dispute?
  payment        Payment?
}
model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int      // 1 to 5 stars
  comment   String?
  createdAt DateTime @default(now())

  @@map("reviews")
}

model Dispute {
  id         String    @id@default(uuid())
  bookingId  String  @unique
  booking    Booking @relation(fields:[bookingId],references:[id],onDelete:Cascade)
  reason     String
  status     String @default("OPEN")
  createdAt  DateTime @default(now())
  @@map("disputes")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  transactionId String   @unique
  amount        Float
  paymentMethod String
  status        String   // e.g. "SUCCESS", "FAILED"
  createdAt     DateTime @default(now())

  @@map("payments")
}
